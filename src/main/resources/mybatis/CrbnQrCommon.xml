<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ilmare.carbonbank.mapper.CrbnQrCommonMapper">

    <insert id="insertDgtQr" parameterType="com.ilmare.carbonbank.model.CrbnQrCommonModel">
        <![CDATA[
            INSERT INTO CRBN_DGT_QR_INFO (
				dgt_qr_cd
            ) VALUES (
              #{dgtQrCd}
            )
        ]]>
    </insert>
    
    <update id="updateMbrPprQrUse" parameterType="com.ilmare.carbonbank.model.CrbnQrCommonModel">
        <![CDATA[
            UPDATE CRBN_PPR_QR_INFO
               SET
                    qr_stat   = 'U'
                    ,qr_use_avail_dtm   =  now()
              WHERE ppr_qr_cd= #{pprQrCd}
        ]]>
    </update>
 
 </mapper>
